# Copy to .env and fill in. NEVER commit .env.
DATABASE_URL=postgresql+asyncpg://perzforge:changeme-db-pass@localhost:5432/perzforge
REDIS_URL=redis://:changeme-redis-pass@localhost:6379/0
JWT_SECRET=generate-with--openssl-rand-hex-32
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
ENVIRONMENT=dev
ALLOWED_IMAGE_PREFIXES=python:,pytorch/,tensorflow/,nvidia/cuda
MAX_CONCURRENT_JOBS_PER_USER=2
JOB_QUEUE_KEY=perzforge:jobs:queue
WORKER_LOCK_KEY=perzforge:worker:lock

# First admin bootstrap (scripts/create_admin.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-long-password
