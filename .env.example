# Copy to .env and fill in. NEVER commit .env.
DATABASE_URL=postgresql+asyncpg://perzforge:changeme-db-pass@localhost:5432/perzforge
REDIS_URL=redis://:changeme-redis-pass@localhost:6379/0
JWT_SECRET=generate-with--openssl-rand-hex-32
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
ENVIRONMENT=dev
ALLOWED_IMAGE_PREFIXES=python:,pytorch/,tensorflow/,nvidia/cuda,ubuntu:
MAX_CONCURRENT_JOBS_PER_USER=2
MAX_JOBS_PER_DAY_PER_USER=10
MAX_STORAGE_MB_PER_USER=2048
MAX_INSTANCES_PER_USER=1
MAX_LLM_TOKENS_PER_DAY_PER_USER=50000

# Rate limits (E2)
RATE_LIMIT_DEFAULT_PER_MIN=60
RATE_LIMIT_DEFAULT_BURST=90
RATE_LIMIT_AUTH_PER_MIN=5
RATE_LIMIT_AUTH_BURST=5
RATE_LIMIT_JOBS_WRITE_PER_HOUR=10
RATE_LIMIT_JOBS_WRITE_BURST=10
RATE_LIMIT_LLM_PER_MIN=20
RATE_LIMIT_LLM_BURST=20
JOB_QUEUE_KEY=perzforge:jobs:queue
WORKER_LOCK_KEY=perzforge:worker:lock

# Object storage + MLflow (B4) — bind to localhost / Tailscale only
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=perzforge
MINIO_SECRET_KEY=changeme-minio-pass
MINIO_BUCKET=models
MINIO_REGION=us-east-1
MINIO_SECURE=false
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# Attach job containers to the compose network so they can reach MLflow (empty = network none)
DOCKER_JOB_NETWORK=

# First admin bootstrap (scripts/create_admin.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-long-password
